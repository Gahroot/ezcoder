<%# locals: frame_id (String), confirmation (EZAgentRails::ToolConfirmation) %>
<%#
  One human-in-the-loop approval card. While the gate is parked the row is
  `pending` and we render Approve / Deny / Always buttons that POST the user's
  decision to ToolConfirmationsController#update; the blocked RunJob polls the
  row and unblocks the moment one is clicked. Once resolved we re-render the same
  frame (via Broadcaster#confirm_resolved) showing the recorded verdict instead.

  Routes are built through EZAgentRails::Engine.routes.url_helpers (rather than
  bare *_path helpers) so the mount prefix is present whether this partial is
  rendered in an engine request OR an out-of-band Turbo broadcast.
%>
<% routes = EZAgentRails::Engine.routes.url_helpers %>
<turbo-frame id="<%= frame_id %>" class="ez-agent-confirm"
             data-tool-name="<%= confirmation.tool_name %>"
             data-confirmation-id="<%= confirmation.id %>"
             data-status="<%= confirmation.status %>">
  <details class="ez-agent-tool__card ez-agent-tool__card--confirm" open>
    <summary class="ez-agent-tool__summary">
      <span class="ez-agent-tool__icon">⚠️</span>
      <span class="ez-agent-tool__name"><%= confirmation.tool_name %></span>
      <span class="ez-agent-tool__badge ez-agent-tool__badge--<%= confirmation.pending? ? "pending" : confirmation.status %>">
        <%= confirmation.pending? ? "approval needed" : confirmation.status.humanize.downcase %>
      </span>
      <span class="ez-agent-tool__chevron"></span>
    </summary>
    <div class="ez-agent-tool__body">
      <div class="ez-agent-tool__section">
        <div class="ez-agent-tool__section-label">Parameters</div>
        <pre class="ez-agent-tool__pre"><%= JSON.pretty_generate(confirmation.args) rescue confirmation.args.to_s %></pre>
      </div>

      <% if confirmation.pending? %>
        <div class="ez-agent-confirm__actions">
          <%= button_to "✅ Approve", routes.confirmation_path(confirmation),
                        params: { decision: "allow" }, class: "ez-agent-confirm__approve" %>
          <%= button_to "❌ Deny", routes.confirmation_path(confirmation),
                        params: { decision: "deny" }, class: "ez-agent-confirm__deny" %>
          <%= button_to "🔄 Always", routes.confirmation_path(confirmation),
                        params: { decision: "always_allow" }, class: "ez-agent-confirm__always" %>
        </div>
      <% end %>
    </div>
  </details>
</turbo-frame>
