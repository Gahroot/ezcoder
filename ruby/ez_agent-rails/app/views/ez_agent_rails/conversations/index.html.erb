<%# locals: @conversations, @provider_status %>
<% content_for :title, "EZ Agent · Conversations" %>

<%= render "ez_agent_rails/conversations/sidebar",
           conversations: @conversations, active_conversation: nil %>

<div class="ez-agent-main">
  <turbo-frame id="ez_agent_main">
    <div class="ez-agent-welcome">
      <div class="ez-agent-welcome__icon"><i data-lucide="bot"></i></div>
      <h1 class="ez-agent-welcome__title">Welcome to EZ Agent</h1>
      <p class="ez-agent-welcome__subtitle">
        Your AI coding assistant. Start a new chat or pick a conversation from the sidebar.
      </p>

      <% if @provider_status.present? %>
        <div class="ez-agent-welcome__providers">
          <% @provider_status.each do |provider| %>
            <div class="ez-agent-provider-card">
              <span class="ez-agent-provider-card__icon"><i data-lucide="<%= provider[:icon] %>"></i></span>
              <div class="ez-agent-provider-card__info">
                <div class="ez-agent-provider-card__name"><%= provider[:display_name] %></div>
                <div class="ez-agent-provider-card__meta">
                  <span class="ez-agent-provider-card__dot <%= provider[:configured] ? 'ez-agent-provider-card__dot--configured' : 'ez-agent-provider-card__dot--missing' %>"></span>
                  <% if provider[:configured] %>
                    Ready · <%= provider[:model_count] %> models
                  <% else %>
                    No API key
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>

      <div class="ez-agent-shortcuts">
        <span><kbd>Enter</kbd> Send</span>
        <span><kbd>Shift</kbd>+<kbd>Enter</kbd> New line</span>
        <span><kbd>Ctrl</kbd>+<kbd>L</kbd> Clear chat</span>
      </div>
    </div>
  </turbo-frame>
</div>
