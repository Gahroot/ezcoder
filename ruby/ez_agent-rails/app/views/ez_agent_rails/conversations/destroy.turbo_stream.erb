<%= turbo_stream.action :replace, "ez_agent_main" do %>
  <turbo-frame id="ez_agent_main">
    <%= render "ez_agent_rails/conversations/sidebar",
               conversations: @conversations, active_conversation: nil %>
    <div class="ez-agent-main">
      <div class="ez-agent-welcome">
        <div class="ez-agent-welcome__icon"><i data-lucide="bot"></i></div>
        <h1 class="ez-agent-welcome__title">Welcome to EZ Agent</h1>
        <p class="ez-agent-welcome__subtitle">
          Your AI coding assistant. Start a new chat or pick a conversation from the sidebar.
        </p>
      </div>
    </div>
  </turbo-frame>
<% end %>
