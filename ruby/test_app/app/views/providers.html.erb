<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>EZLLM Providers Config</title>
  <style>
    :root {
      --bg: #0f1117;
      --surface: #1a1d27;
      --border: #2a2d3a;
      --text: #e1e4ed;
      --text-dim: #8b8fa3;
      --accent: #6c5ce7;
      --accent-light: #a29bfe;
      --green: #00cec9;
      --green-dim: rgba(0, 206, 201, 0.12);
      --red: #ff6b6b;
      --red-dim: rgba(255, 107, 107, 0.12);
      --orange: #fdcb6e;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, monospace;
      background: var(--bg);
      color: var(--text);
      padding: 2rem;
      line-height: 1.6;
    }

    header {
      max-width: 960px;
      margin: 0 auto 2rem;
    }

    header h1 {
      font-size: 1.75rem;
      font-weight: 700;
      letter-spacing: -0.02em;
    }

    header h1 span { color: var(--accent-light); }

    header p {
      color: var(--text-dim);
      margin-top: 0.5rem;
      font-size: 0.9rem;
    }

    .summary {
      display: flex;
      gap: 1.5rem;
      margin: 1.5rem 0;
      flex-wrap: wrap;
    }

    .summary .stat {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 1rem 1.5rem;
      min-width: 140px;
    }

    .stat .label { color: var(--text-dim); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.08em; }
    .stat .value { font-size: 1.5rem; font-weight: 700; margin-top: 0.25rem; }
    .stat .value.green { color: var(--green); }
    .stat .value.orange { color: var(--orange); }

    .providers {
      max-width: 960px;
      margin: 0 auto;
      display: grid;
      gap: 1rem;
    }

    .provider-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1.25rem 1.5rem;
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 1rem;
      align-items: start;
      transition: border-color 0.2s;
    }

    .provider-card:hover { border-color: var(--accent); }

    .provider-card .name {
      font-weight: 600;
      font-size: 1.05rem;
    }

    .provider-card .env-key {
      font-family: 'SF Mono', 'Fira Code', monospace;
      font-size: 0.8rem;
      color: var(--text-dim);
      background: rgba(108, 92, 231, 0.08);
      padding: 0.2rem 0.5rem;
      border-radius: 4px;
      display: inline-block;
      margin-top: 0.35rem;
    }

    .provider-card .status {
      font-size: 0.8rem;
      padding: 0.25rem 0.75rem;
      border-radius: 20px;
      font-weight: 600;
      white-space: nowrap;
    }

    .status.configured {
      background: var(--green-dim);
      color: var(--green);
    }

    .status.missing {
      background: var(--red-dim);
      color: var(--red);
    }

    .provider-card .models {
      grid-column: 1 / -1;
      margin-top: 0.5rem;
      padding-top: 0.75rem;
      border-top: 1px solid var(--border);
    }

    .models .default-model {
      font-size: 0.85rem;
      color: var(--accent-light);
      font-weight: 500;
    }

    .models .all-models {
      margin-top: 0.4rem;
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
    }

    .model-tag {
      font-family: 'SF Mono', 'Fira Code', monospace;
      font-size: 0.72rem;
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid var(--border);
      padding: 0.15rem 0.5rem;
      border-radius: 4px;
      color: var(--text-dim);
    }

    .model-tag.default {
      border-color: var(--accent);
      color: var(--accent-light);
      background: rgba(108, 92, 231, 0.08);
    }

    footer {
      max-width: 960px;
      margin: 2rem auto 0;
      padding-top: 1rem;
      border-top: 1px solid var(--border);
      color: var(--text-dim);
      font-size: 0.75rem;
    }
  </style>
</head>
<body>
  <header>
    <h1><span>EZLLM</span> Providers Config</h1>
    <p>Registered providers and their default models — wired via <code>config/initializers/ez_llm_providers.rb</code></p>
  </header>

  <div class="summary">
    <div class="stat">
      <div class="label">Providers</div>
      <div class="value"><%= providers.size %></div>
    </div>
    <div class="stat">
      <div class="label">Configured</div>
      <div class="value green"><%= providers.count { |p| p[:env_key] && ENV[p[:env_key]] && !ENV[p[:env_key]].empty? } %></div>
    </div>
    <div class="stat">
      <div class="label">Missing Keys</div>
      <div class="value orange"><%= providers.count { |p| !(p[:env_key] && ENV[p[:env_key]] && !ENV[p[:env_key]].empty?) } %></div>
    </div>
    <div class="stat">
      <div class="label">Total Models</div>
      <div class="value"><%= providers.sum { |p| p[:models].size } %></div>
    </div>
  </div>

  <div class="providers">
    <% providers.each do |provider| %>
      <%
        configured = provider[:env_key] && ENV[provider[:env_key]] && !ENV[provider[:env_key]].empty?
      %>
      <div class="provider-card">
        <div>
          <div class="name"><%= provider[:display_name] %></div>
          <div class="env-key"><%= provider[:env_key] %></div>
        </div>
        <div class="status <%= configured ? 'configured' : 'missing' %>">
          <%= configured ? '● Configured' : '○ Missing' %>
        </div>
        <div class="models">
          <div class="default-model">Default: <%= provider[:default_model_name] %> (<code><%= provider[:default_model_id] %></code>)</div>
          <div class="all-models">
            <% provider[:models].each do |model| %>
              <span class="model-tag <%= 'default' if model[:id] == provider[:default_model_id] %>"><%= model[:id] %></span>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <footer>
    Generated by EZLLM Test App · Providers registered via <code>EZLLM::ProviderRegistry</code> · Models from <code>EZLLM::ModelRegistry</code>
  </footer>
</body>
</html>
