{
  "name": "ezcoder",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm -r check",
    "lint": "eslint packages/ai/src/ packages/agent/src/ packages/cli/src/ packages/pixel/src/ packages/pixel-server/src/ packages/ezcoder-eyes/src/",
    "lint:fix": "eslint packages/ai/src/ packages/agent/src/ packages/cli/src/ packages/pixel/src/ packages/pixel-server/src/ packages/ezcoder-eyes/src/ --fix",
    "format": "prettier --write \"packages/{ai,agent,cli,pixel,pixel-server,ezcoder-eyes}/src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"packages/{ai,agent,cli,pixel,pixel-server,ezcoder-eyes}/src/**/*.{ts,tsx}\"",
    "test": "pnpm -r test",
    "prepare": "pnpm build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typescript-eslint": "^8.59.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "onnxruntime-node"
    ],
    "overrides": {
      "global-agent": "^4.1.3"
    }
  }
}
