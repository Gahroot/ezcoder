<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
      Tauri merges this into the generated app Info.plist on macOS. The webcam
      gaze tracker calls getUserMedia, which WKWebView refuses (and the app
      crashes) unless the camera usage description string is present.
    -->
    <key>NSCameraUsageDescription</key>
    <string>GG Coder uses your camera locally to track which window you're looking at and focus it. Video never leaves your machine.</string>
</dict>
</plist>
