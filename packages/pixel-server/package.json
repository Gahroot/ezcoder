{
  "name": "@prestyj/pixel-server",
  "version": "4.3.83",
  "private": true,
  "type": "module",
  "description": "Cloudflare Workers backend for pixel",
  "scripts": {
    "check": "tsc --noEmit",
    "test": "vitest run",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:local": "wrangler d1 execute ez-pixel --local --file=./migrations/0001_init.sql",
    "db:remote": "wrangler d1 execute ez-pixel --remote --file=./migrations/0001_init.sql"
  },
  "dependencies": {
    "hono": "^4.6.13"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "@types/better-sqlite3": "^7.6.12",
    "better-sqlite3": "^11.7.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4",
    "wrangler": "^3.99.0"
  }
}
