{
  "name": "@prestyj/editor",
  "version": "0.6.3",
  "type": "module",
  "description": "CLI video editor agent. Drives DaVinci Resolve and Premiere Pro via API + hotkeys + GUI fallback.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Gahroot/ezcoder.git",
    "directory": "packages/editor"
  },
  "bin": {
    "ggeditor": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:skills": "node scripts/build-skills.mjs",
    "build": "node scripts/build-skills.mjs && tsc",
    "check": "node scripts/build-skills.mjs && tsc --noEmit",
    "test": "node scripts/build-skills.mjs && vitest run"
  },
  "dependencies": {
    "@prestyj/agent": "workspace:*",
    "@prestyj/ai": "workspace:*",
    "@prestyj/cli": "workspace:*",
    "chalk": "^5.6.2",
    "ink": "^6.8.0",
    "react": "^19.2.5",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/ws": "^8.5.13",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
