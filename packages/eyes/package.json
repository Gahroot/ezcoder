{
  "name": "@prestyj/eyes",
  "version": "0.1.4",
  "type": "module",
  "description": "Project-agnostic perception probes for coding agents — screenshots, logs, APIs, capture sinks",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Gahroot/ezcoder.git",
    "directory": "packages/eyes"
  },
  "bin": {
    "ezcoder-eyes": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": "./dist/cli.js",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "probes",
    "shared"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js || true",
    "check": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
