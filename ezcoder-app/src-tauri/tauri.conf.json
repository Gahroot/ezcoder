{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EZ Coder",
  "version": "0.1.26",
  "identifier": "com.prestyj.ezcoder",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": ["binaries/eznode"],
    "resources": ["sidecar/"],
    "macOS": {
      "entitlements": "entitlements.plist",
      "dmg": {
        "background": "../installer/out/dmg-background.png",
        "windowSize": { "width": 660, "height": 400 },
        "appPosition": { "x": 180, "y": 170 },
        "applicationFolderPosition": { "x": 480, "y": 170 }
      }
    },
    "windows": {
      "nsis": {
        "headerImage": "../installer/out/nsis-header.bmp",
        "sidebarImage": "../installer/out/nsis-sidebar.bmp",
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE3MUUyNUQyMDdBNkMyRkIKUldUN3dxWUgwaVVlcHc4aTZ6VThlOXNjV3llMm1UWFhvMmRtTWRHcEFnMVJvWEJGN3F3TmN2Q0cK",
      "endpoints": [
        "https://github.com/Gahroot/ezcoder/releases/latest/download/latest.json"
      ]
    }
  }
}
